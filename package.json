    "@capacitor/filesystem": "^6.0.0",
    "libsodium-wrappers": "^0.7.15",
    "libsodium-wrappers-sumo": "^0.8.4",
    "lucide-react": "^0.447.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.26.0",
    "shamirs-secret-sharing": "^2.0.1"
