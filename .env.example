# Arkive — environment variable template
# Copy to .env and fill in values.
# NEVER commit .env or any real key material to the repo.

# Ed25519 public key (base64) used to verify signed APK update manifests.
# Generate the keypair offline with libsodium; keep the private key out of this repo.
# Store the private key in CI secrets only. Leave empty to reject all updates (safe default).
VITE_UPDATE_PUBKEY=

# Base URL of the Cloudflare relay Worker.
# Leave empty to run fully local/offline (correct for Phase 0 and Phase 1).
VITE_RELAY_URL=
